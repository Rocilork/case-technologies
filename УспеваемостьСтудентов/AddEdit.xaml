<Page x:Class="УспеваемостьСтудентов.AddEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УспеваемостьСтудентов"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEdit">

    <Grid>
        <Button Content="Сохранить" HorizontalAlignment="Left" Margin="91,374,0,0" VerticalAlignment="Top" Width="113" Height="37" Click="Button_Click_1"/>
        <Button Content="Выйти" HorizontalAlignment="Left" Margin="376,374,0,0" VerticalAlignment="Top" Width="113" Height="37" Click="Button_Click"/>
        <Label Content="Дата сдачи" HorizontalAlignment="Left" Margin="123,60,0,0" VerticalAlignment="Top"/>
        <Label Content="Оценка" HorizontalAlignment="Left" Margin="123,112,0,0" VerticalAlignment="Top"/>
        <Label Content="Студент" HorizontalAlignment="Left" Margin="123,162,0,0" VerticalAlignment="Top"/>
        <Label Content="Преподаватель" HorizontalAlignment="Left" Margin="123,231,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="comboBox" SelectedItem="{Binding Студенты}" DisplayMemberPath="ФИО_студента" HorizontalAlignment="Left" Margin="227,166,0,0" VerticalAlignment="Top" Width="120"/>
        <ComboBox x:Name="comboBox1" SelectedItem="{Binding Преподаватели}" DisplayMemberPath="ФИО_преподавателя" HorizontalAlignment="Left" Margin="227,235,0,0" VerticalAlignment="Top" Width="120"/>
        <DatePicker x:Name="date" SelectedDate="{Binding Дата_сдачи}" HorizontalAlignment="Left" Margin="227,60,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="time" HorizontalAlignment="Left" Height="23" Margin="227,115,0,0" TextWrapping="Wrap" Text="{Binding Оценка}" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="com" HorizontalAlignment="Left" Height="23" Margin="491,231,0,0" TextWrapping="Wrap" Text="{Binding Рейтинг_КН}" VerticalAlignment="Top" Width="120"/>
        <Label Content="Рейтинг" HorizontalAlignment="Left" Margin="393,231,0,0" VerticalAlignment="Top"/>
        <Label Content="Предмет" HorizontalAlignment="Left" Margin="123,291,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="comboBox2" SelectedItem="{Binding Предметы}" DisplayMemberPath="Название" HorizontalAlignment="Left" Margin="227,293,0,0" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Page>
