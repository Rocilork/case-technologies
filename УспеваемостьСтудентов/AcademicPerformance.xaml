<Page x:Class="УспеваемостьСтудентов.AcademicPerformance"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:УспеваемостьСтудентов"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AcademicPerformance">

    <Grid>
        <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" IsReadOnly="True" HorizontalAlignment="Left" Height="287" VerticalAlignment="Top" Width="800">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID успеваемости" Binding="{Binding ID_Успеваемости}"/>
                <DataGridTextColumn Header="Предмет" Binding="{Binding Предметы.Название}"/>
                <DataGridTextColumn Header="Рейтинг КН" Binding="{Binding Рейтинг_КН}"/>
                <DataGridTextColumn Header="Дата сдачи" Binding="{Binding Дата_сдачи, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Оценка}"/>
                <DataGridTextColumn Header="Студенты" Binding="{Binding Студенты.ФИО_студента}"/>
                <DataGridTextColumn Header="Преподаватели" Binding="{Binding Преподаватели.ФИО_преподавателя}"/>

                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Изменить" Click="Button_Click_2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Добавить" HorizontalAlignment="Left" Margin="106,350,0,0" VerticalAlignment="Top" Width="105" Height="36" Click="Button_Click"/>
        <Button Content="Удалить" HorizontalAlignment="Left" Margin="486,350,0,0" VerticalAlignment="Top" Width="105" Height="36" Click="Button_Click_1"/>
    </Grid>
</Page>
